# 仅供本地联调的示例值；生产部署必须全部替换为独立随机 secret。
AIWS_DB_ADMIN_PASSWORD=local-admin-change-before-production
AIWS_DB_MIGRATOR_PASSWORD=local-migrator-change-before-production
AIWS_DB_APP_PASSWORD=local-app-change-before-production
AIWS_DB_DASHBOARD_PASSWORD=local-dashboard-change-before-production
AIWS_DASHBOARD_OPERATOR_TOKEN=local-dashboard-token-change-before-production

# development 默认使用受限 mock 身份、模型和 renderer，便于本机联调。
AIWS_ENVIRONMENT=development
AIWS_PUBLIC_BASE_URL=http://127.0.0.1:8000
AIWS_BACKEND_PORT=8000
AIWS_DASHBOARD_PORT=8010

# production 必须改为 production/trusted_proxy_hmac，并提供至少 32-byte HMAC secret。
AIWS_IDENTITY_MODE=
AIWS_TRUSTED_PROXY_HMAC_SECRET=

# 非 mock OpenAI-compatible provider 还需要填写以下四项。
AIWS_AI_PROVIDER=mock
AIWS_AI_MODEL=mock-deterministic-v1
AIWS_AI_BASE_URL=
AIWS_AI_DATA_REGION=private_deployment
AIWS_LLM_API_KEY=
