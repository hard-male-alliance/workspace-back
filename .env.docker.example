# PostgreSQL 管理密码仅由官方镜像初始化 postgres 管理角色；dbctl 会自行生成应用角色密码。
AIWS_DB_ADMIN_PASSWORD=local-admin-change-before-production
AIWS_DASHBOARD_OPERATOR_TOKEN=local-dashboard-token-change-before-production

# development 默认使用受限 mock 身份、模型和 renderer，便于本机联调。
AIWS_ENVIRONMENT=development
AIWS_PUBLIC_BASE_URL=http://dev.hmalliances.org:9000
AIWS_BACKEND_PORT=9000
AIWS_DASHBOARD_PORT=8010

# API V2 production 固定关闭 legacy proxy identity；仅配置 V2 多 worker 共享密钥。
AIWS_CURSOR_HMAC_SECRET=
AIWS_SENSITIVE_IDEMPOTENCY_HMAC_SECRET=

# Hosted identity outbox：active key ID 必须存在于 JSON keyring；两个 key domain 均为
# 无 padding 的 32-byte base64url，轮换期间保留仍有 pending row 的旧 AES key。
AIWS_IDENTITY_EMAIL_ACTIVE_KEY_ID=
AIWS_IDENTITY_EMAIL_ENCRYPTION_KEYS={}
AIWS_IDENTITY_EMAIL_RATE_LIMIT_HMAC_KEY=
AIWS_IDENTITY_EMAIL_FROM_ADDRESS=
AIWS_IDENTITY_EMAIL_SMTP_HOST=
# 可使用无认证的私有 relay；若配置认证，username/password 必须同时填写。
AIWS_IDENTITY_EMAIL_SMTP_USERNAME=
AIWS_IDENTITY_EMAIL_SMTP_PASSWORD=

# 非 mock OpenAI-compatible provider 还需要填写以下四项。
AIWS_AI_PROVIDER=mock
AIWS_AI_MODEL=mock-deterministic-v1
AIWS_AI_BASE_URL=
AIWS_AI_DATA_REGION=private_deployment
AIWS_AI_EMBEDDING_PROVIDER=mock
AIWS_AI_EMBEDDING_MODEL=mock-embedding-1024
AIWS_AI_EMBEDDING_MODEL_REVISION=v1
AIWS_AI_EMBEDDING_DIMENSION=1024
AIWS_LLM_API_KEY=
AIWS_RESUME_RENDERER_ADAPTER=mock
AIWS_RESUME_XELATEX_COMMAND=xelatex

# Knowledge Connection：两个 AES-256 keyring 与两个 HMAC domain 必须使用四份不同的
# 无 padding 32-byte base64url 材料。providers 是完整 provider allowlist 的 JSON 数组。
AIWS_KNOWLEDGE_CONNECTION_PROVIDERS=[]
AIWS_KNOWLEDGE_PROVIDER_SESSION_ACTIVE_KEY_ID=
AIWS_KNOWLEDGE_PROVIDER_SESSION_KEYS={}
AIWS_KNOWLEDGE_CREDENTIAL_ACTIVE_KEY_ID=
AIWS_KNOWLEDGE_CREDENTIAL_KEYS={}
AIWS_KNOWLEDGE_CREDENTIAL_FINGERPRINT_HMAC_KEY=
AIWS_KNOWLEDGE_CREDENTIAL_REFERENCE_HMAC_KEY=

# Docker 总是使用 PostgreSQL；development 的 local upload 也必须显式提供稳定签名 key。
# production 改用 S3-compatible HTTPS endpoint 与显式 SigV4 credentials。
AIWS_KNOWLEDGE_LOCAL_UPLOAD_SIGNING_HMAC_KEY=
AIWS_KNOWLEDGE_S3_ENDPOINT=
AIWS_KNOWLEDGE_S3_REGION=
AIWS_KNOWLEDGE_S3_BUCKET=
AIWS_KNOWLEDGE_S3_ACCESS_KEY_ID=
AIWS_KNOWLEDGE_S3_SECRET_ACCESS_KEY=
AIWS_KNOWLEDGE_S3_SESSION_TOKEN=
AIWS_KNOWLEDGE_S3_OBJECT_PREFIX=aiws-uploads

# production 缺 scanner 时使用 reject（fail closed）；启用 clamav 时填写 host/port。
AIWS_KNOWLEDGE_MALWARE_MODE=
AIWS_KNOWLEDGE_CLAMAV_HOST=
AIWS_KNOWLEDGE_CLAMAV_PORT=3310

# 初始 URL 与每一跳 redirect 共用的精确 hostname/"*.suffix" JSON allowlist。
AIWS_KNOWLEDGE_SOURCE_ALLOWED_HOST_PATTERNS=[]

# Interview V2 realtime：keyring 值为无 padding 32-byte base64url。
# staging/production 必须显式配置 active key 与非占位 HTTPS/WSS endpoint。
AIWS_INTERVIEW_REALTIME_ACTIVE_KEY_ID=
AIWS_INTERVIEW_REALTIME_SIGNING_KEYS={}
AIWS_INTERVIEW_SIGNALING_URL=
# RFC 7064/7065 STUN/TURN URI 的 JSON 数组，可以显式为空。
AIWS_INTERVIEW_ICE_URLS=[]
