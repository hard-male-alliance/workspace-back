// @brief 完整配置示例 / Complete configuration example.
// @note dbctl 复制本模板为被 Git 忽略的 config.jsonc，并将生成的数据库 DSN 写入副本。
{
  // 运行环境标签；development、test、staging 或 production。
  "environment": "development",
  "workspace": {
    // 未接入认证前的开发默认身份；生产环境由认证中间件覆盖。
    "default_actor_id": "usr_local_demo",
    // 每一个 Repository 查询必须携带此 workspace 范围。
    "default_workspace_id": "ws_local_demo",
    // 资源所有者；用于防止未来认证接入时发生越权考古。
    "default_resource_owner_id": "usr_local_demo"
  },
  "network": {
    // Nginx 后的内部监听地址和端口；客户端不可假设可直连。
    "bind_host": "127.0.0.1",
    "bind_port": 8000,
    // 生成短期回调/连接描述时使用的外部基址。
    "public_base_url": "https://workspace.example.cn",
    // 浏览器可访问产品 API 的精确 Origin；生产建议同源部署并保留空数组。
    "cors_allowed_origins": [],
    // trusted_proxy_hmac 只接受这些实际 TCP 对端的签名断言；绝不信任客户端 forwarded headers。
    "trusted_proxy_cidrs": ["127.0.0.1/32"],
    // 统一为所有外部 HTTP 客户端配置的可选代理；null 表示禁用。
    "outbound_proxy_url": null,
    "connect_timeout_ms": 3000,
    "read_timeout_ms": 15000
  },
  "database": {
    // memory 仅用于确定性开发/测试；production 必须是 postgresql。
    "mode": "memory",
    // dbctl 初始化 config.jsonc 时写入三个独立角色及随机密码；模板本身不含 secret。
    "application_dsn": null,
    "migrator_dsn": null,
    // Dashboard 只能使用该只读角色的独立 DSN，绝不复用 application DSN。
    "dashboard_dsn": null,
    // 单一长生命周期连接池上限，禁止请求路径临时无限建连。
    "pool_size": 10,
    "max_overflow": 10,
    "connect_timeout_ms": 3000,
    // 每个 application 短事务强制 SQL 与锁等待上限，避免慢查询长期占用 worker/pool。
    "statement_timeout_ms": 30000,
    "lock_timeout_ms": 3000
  },
  "runtime": {
    "shutdown_grace_ms": 10000,
    "request_timeout_ms": 30000,
    "llm_concurrency": 8,
    "render_concurrency": 2,
    "knowledge_concurrency": 2,
    "interview_concurrency": 16,
    "job_queue_capacity": 256,
    "sse_heartbeat_ms": 15000
  },
  // Local modular-monolith blob adapter. Mount a durable private volume in production.
  "knowledge": {
    "blob_directory": "data/knowledge-blobs",
    "max_upload_bytes": 10485760,
    "max_extracted_characters": 1000000,
    "chunk_max_characters": 800,
    "chunk_overlap_characters": 80
  },
  "resume_rendering": {
    // mock 用于可重复测试；xelatex 启用受限子进程编译器。
    "adapter": "mock",
    "xelatex_command": "xelatex",
    "timeout_ms": 30000,
    "max_input_bytes": 1048576,
    "max_output_bytes": 10485760,
    "memory_limit_bytes": 536870912,
    // 为空时 XeLaTeX 适配器只使用内置受控模板，不接受用户路径。
    "allowed_font_directories": [],
    "artifact_directory": "artifacts"
  },
  "ai": {
    // mock、openrouter 或经确认的中国可用 provider；公开 API 不暴露该选择。
    "provider": "mock",
    // 仅服务端可见。openrouter 示例可用 openai/gpt-5-mini；mock 时使用稳定名称。
    "model": "mock-deterministic-v1",
    // 非 mock endpoint 的实际数据处理地域；每个 fallback 也必须显式声明该字段。
    "data_region": "private_deployment",
    // fallback 必须显式拥有自己的 endpoint 和 key，避免跨服务商误用凭证。
    // [{"provider": "openrouter", "model": "...", "api_key_env": "...", "base_url": "https://openrouter.ai/api/v1", "data_region": "global"}]
    "fallback_providers": [],
    "api_key_env": "AIWS_LLM_API_KEY",
    "base_url": null,
    "embedding_provider": "mock",
    "embedding_model": "mock-embedding-1024",
    "embedding_model_revision": "v1",
    "embedding_dimension": 1024,
    "embedding_distance_metric": "cosine",
    "embedding_normalization": "l2",
    // 每个实际模型 endpoint 在单一 backend worker 内独立使用该并发/每分钟请求预算；超时返回可重试的 429。
    // 多 worker 部署需按 worker 数量向供应商申请配额，或在入口层补充全局配额。
    "provider_rate_limit": {
      "max_concurrent_requests": 4,
      "requests_per_minute": 60,
      "acquire_timeout_ms": 1000
    },
    // 本地 token 估算的价格；单位为每百万 token 的 micro-USD。0 是不编造供应商价格的安全默认值。
    "metering": {
      "input_cost_microusd_per_million_tokens": 0,
      "output_cost_microusd_per_million_tokens": 0
    }
  },
  "observability": {
    "enabled": true,
    "queue_capacity": 2048,
    "batch_size": 100,
    "flush_interval_ms": 1000,
    "shutdown_flush_timeout_ms": 5000,
    "retention_days": 30,
    // drop_newest 或 drop_oldest；丢失 telemetry 不能拖垮业务请求。
    "drop_policy": "drop_newest",
    // 独立小连接池隔离 telemetry 写入与业务 SQL，writer 自身绝不递归记录日志。
    "writer": {
      "pool_size": 2,
      "connect_timeout_ms": 1000,
      "statement_timeout_ms": 2000,
      "lock_timeout_ms": 500
    },
    // 浏览器诊断在 JSON 解析前限制原始 body，并按 ActorScope 使用有界 token bucket。
    "diagnostics": {
      "max_body_bytes": 65536,
      "max_batch_size": 50,
      "max_event_age_seconds": 86400,
      "max_future_skew_seconds": 300,
      "rate_limit_capacity": 100,
      "rate_limit_refill_per_minute": 200,
      "max_actor_buckets": 10000
    }
  },
  "logging": {
    "queue_capacity": 2048,
    // 所有 route 独立 worker 共享该总关闭预算；超时 worker 由 daemon reaper 回收。
    "shutdown_timeout_ms": 5000,
    // true 时将同一 event_id 的稳定事件异步 fan-out 到 observability 数据库。
    "persist_structured_events": true,
    // 每条 route 使用精确等级集合；ERROR 不会因 threshold 语义重复进入 stdout。
    "routes": [
      {"sink": "stdout", "levels": ["DEBUG", "INFO"]},
      {"sink": "stderr", "levels": ["WARNING", "ERROR", "CRITICAL"]},
      {
        "sink": "file",
        "levels": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"],
        "path": "data/logs/backend.jsonl",
        "max_bytes": 10485760,
        "backup_count": 5
      }
    ]
  },
  "security": {
    // development/test 允许 development_mock；staging/production 必须为 trusted_proxy_hmac。
    "identity_mode": "development_mock",
    // 只写变量名；生产入口代理与后端共享的密钥必须至少 32 bytes，禁止提交实际值。
    "trusted_proxy_hmac_secret_env": "AIWS_TRUSTED_PROXY_HMAC_SECRET",
    // 代理和应用服务器的签名时钟双向偏差，上限 600 秒。
    "trusted_proxy_max_clock_skew_seconds": 300
  },
  "dashboard": {
    // 内部只读运维面；mock 仅可用于 development/test，staging/production 与 postgresql 强制 operator_token。
    "enabled": true,
    "api": {"host": "127.0.0.1", "port": 8010, "prefix": "/dashboard/v1"},
    // Overview 始终聚合完整窗口；趋势由 PostgreSQL date_bin 分桶，只有事件流使用硬 limit。
    "query": {
      "default_window_minutes": 60,
      "max_window_hours": 168,
      "timeout_ms": 3000,
      "freshness_target_seconds": 120,
      "target_points": 600,
      "max_event_limit": 500
    },
    "access": {
      // development/test 可用 mock；staging/production 或 postgresql 模式必须设为 operator_token。
      "mode": "mock",
      "operator_id": "workspace_dashboard",
      "token_env": "AIWS_DASHBOARD_OPERATOR_TOKEN",
      "token_header": "X-Dashboard-Operator-Token"
    },
    // SLO 用于解释错误预算燃烧；HTTP duration 在 canonical 表中以秒存储，呈现层转换为毫秒。
    "health": {
      "warning_error_rate": 0.01,
      "latency_target": 0.95,
      "warning_latency_ms": 1000,
      "period_days": 30
    }
  }
}
